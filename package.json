{
  "name": "nuxt-app",
  "author": "irwinarruda",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test": "concurrently -n nuxt,vitest -c red,blue --hide nuxt -k -s command-vitest \"nuxt dev\" \"vitest run\"",
    "test:watch": "vitest --watch",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:ready": "bun services:up && node ./infra/scripts/wait-for-postgres.js && bun migrations:up",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations up",
    "migrations:down": "node-pg-migrate -m infra/migrations down",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "nuxt typecheck",
    "secrets": "secretlint \"**/*\"",
    "commit": "cz",
    "clean": "rm -rf .nuxt .output node_modules",
    "pretest": "bun services:ready",
    "posttest": "bun services:down",
    "predev": "bun services:ready",
    "postinstall": "nuxt prepare",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.2",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.4",
    "node-pg-migrate": "^8.0.4",
    "nuxt": "^4.4.6",
    "pg": "^8.21.0",
    "uuid": "^11.1.1",
    "vue": "^3.5.35",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@faker-js/faker": "^10.4.0",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node-pg-migrate": "^2.3.1",
    "@types/pg": "^8.20.0",
    "@vue/test-utils": "^2.4.10",
    "add": "^2.0.6",
    "bun": "^1.3.14",
    "commitizen": "^4.3.1",
    "concurrently": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv-expand": "^13.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "secretlint": "^13.0.2",
    "tailwindcss": "^4.3.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "bun@1.3.6",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
