{
	"name": "clone-tabnews",
	"version": "0.0.1",
	"private": true,
	"license": "MIT",
	"scripts": {
		"dev:local": "pnpm services:up && vite dev",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint:check": "prettier --plugin-search-dir . --check . && eslint .",
		"lint:fix": "prettier --plugin-search-dir . --write .",
		"services:up": "docker compose -f ./infra/compose.yaml up -d",
		"services:down": "docker compose -f ./infra/compose.yaml down",
		"services:stop": "docker compose -f ./infra/compose.yaml stop",
		"test": "jest --config ./tests/jest.config.js",
		"test:watch": "jest --watch --config ./tests/jest.config.js",
		"migrations:create": "node-pg-migrate -f ./infra/migrations.config.json create",
		"migrations:up": "node-pg-migrate -f ./infra/migrations.config.json up",
		"migrations:down": "node-pg-migrate -f ./infra/migrations.config.json down"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/kit": "^1.5.0",
		"@types/jest": "^29.5.4",
		"@types/pg": "^8.10.9",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"dotenv": "^16.4.4",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.26.0",
		"jest": "29.6.2",
		"node-pg-migrate": "^6.2.2",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.8.1",
		"svelte": "^3.54.0",
		"svelte-check": "^3.0.1",
		"svelte-jester": "^3.0.0",
		"svelte-preprocess": "^5.0.4",
		"ts-jest": "^29.1.1",
		"ts-node": "^10.9.2",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.3.0"
	},
	"type": "module",
	"dependencies": {
		"pg": "^8.11.3"
	}
}
